# Chompy Backend Environment Variables
# Copy this file to .env and fill in values

# --- Application ---
APP_NAME=Chompy API
APP_VERSION=0.1.0
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://chompy:chompy@postgres:5432/chompy

# --- S3 / MinIO (Image Storage) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=chompy-images

# --- LLM Integration ---
# API key for the multimodal model (GPT-4V / Claude Vision / etc.)
LLM_API_KEY=
LLM_MODEL=gpt-4o

# --- CORS ---
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*
